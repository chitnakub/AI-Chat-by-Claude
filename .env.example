# Copy to .env and fill in. NEVER commit .env.
#
# Your AIRS-GW API key.
# This stays on the server and is never sent to the browser.
AIRS_GW_API_KEY=

# AIRS-GW gateway base URL. Point this at your gateway host.
# For a self-hosted gateway, point this at your own host.
# This is also the default that pre-fills the "gateway URL" field in the UI;
# the UI can override it per-request (see ALLOWED_GATEWAY_HOSTS to lock that down).
AIRS_GW_BASE_URL=http://your-airs-gw/v1

# Optional comma-separated allowlist of hostnames the UI may point the gateway
# URL at. The AIRS_GW_BASE_URL host is always allowed. Leave blank to allow any
# http(s) host. Set this if the UI is reachable by untrusted users.
# e.g. ALLOWED_GATEWAY_HOSTS=your-airs-gw,gateway.internal.example.com
ALLOWED_GATEWAY_HOSTS=

# Default AIRS-GW config slug used when the UI field is left empty.
# Leave blank if you always set the config from the UI.
DEFAULT_AIRS_GW_CONFIG=

# Default model to send to Vertex via AIRS-GW (overridable in the UI).
DEFAULT_MODEL=gemini-2.0-flash

# Port for the local server.
PORT=3000
